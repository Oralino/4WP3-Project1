<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Game</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="container mt-5" style="max-width: 600px;">
        <h2 class="mb-4">Add a New Game</h2>
        
        {{#error}}
        <div class="alert alert-danger">{{error}}</div>
        {{/error}}

        <form method="POST" action="/create" class="card p-4 shadow-sm">
            <div class="mb-3">
                <label class="form-label">Game Title</label>
                <input type="text" name="title" class="form-control" value="{{title}}">
            </div>
            
            <div class="mb-3">
                <label class="form-label">Playtime (Hours)</label>
                <input type="number" step="0.1" name="playtime_hours" class="form-control" value="{{playtime_hours}}">
            </div>

            <div class="mb-3">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                    <option value="Backlog">Backlog</option>
                    <option value="In Progress">In Progress</option>
                    <option value="Completed">Completed</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Personal Rating (1-10)</label>
                <input type="number" name="personal_rating" class="form-control" value="{{personal_rating}}">
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a href="/all" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Save Game</button>
            </div>
        </form>
    </div>

</body>
</html>