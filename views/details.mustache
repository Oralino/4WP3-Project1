<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{game.title}} - Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="container mt-5" style="max-width: 600px;">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <h3 class="mb-0">{{game.title}}</h3>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item"><strong>Status:</strong> {{game.status}}</li>
                    <li class="list-group-item"><strong>Playtime:</strong> {{game.playtime_hours}} hours</li>
                    <li class="list-group-item"><strong>Personal Rating:</strong> {{game.personal_rating}} / 10</li>
                    <li class="list-group-item"><strong>Date Added:</strong> {{game.date_added}}</li>
                </ul>
                
                <div class="d-flex justify-content-between">
                    <a href="/all" class="btn btn-outline-secondary">Back to Library</a>
                    <div>
                        <a href="/edit/{{game.rowid}}" class="btn btn-primary">Edit</a>
                        <a href="/delete/{{game.rowid}}" class="btn btn-danger">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>