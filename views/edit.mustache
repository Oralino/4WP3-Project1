<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Game</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5" style="max-width: 600px;">
        <h2 class="mb-4">Edit Game Details</h2>
        
        {{#error}}
        <div class="alert alert-danger">{{error}}</div>
        {{/error}}

        <form method="POST" action="/update" class="card p-4 shadow-sm">
            <input type="hidden" name="id" value="{{game.rowid}}">

            <div class="mb-3">
                <label class="form-label">Game Title</label>
                <input type="text" name="title" class="form-control" value="{{game.title}}">
            </div>
            
            <div class="mb-3">
                <label class="form-label">Playtime (Hours)</label>
                <input type="number" step="0.1" name="playtime_hours" class="form-control" value="{{game.playtime_hours}}">
            </div>

            <div class="mb-3">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                    <option value="Backlog" {{#game.isBacklog}}selected{{/game.isBacklog}}>Backlog</option>
                    <option value="In Progress" {{#game.isInProgress}}selected{{/game.isInProgress}}>In Progress</option>
                    <option value="Completed" {{#game.isCompleted}}selected{{/game.isCompleted}}>Completed</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Personal Rating (1-10)</label>
                <input type="number" name="personal_rating" class="form-control" value="{{game.personal_rating}}">
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a href="/all" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Update Game</button>
            </div>
        </form>
    </div>
</body>
</html>