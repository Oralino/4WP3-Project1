<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Steam Backlog Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/all">Steam Backlog</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/add">Add Game</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <h2 class="mb-4">My Game Library</h2>
        
        <div class="row">
            {{#games}}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">{{title}}</h5>
                        <p class="card-text">
                            <strong>Status:</strong> {{status}} <br>
                            <strong>Playtime:</strong> {{playtime_hours}} hrs <br>
                            <strong>Rating:</strong> {{personal_rating}}/10
                        </p>
                    </div>
                    <div class="card-footer bg-white border-top-0">
                        <a href="/edit/{{rowid}}" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a href="/delete/{{rowid}}" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
            {{/games}}
        </div>

        <hr>
        <p class="text-muted text-center">Total Games in Library: {{totalGames}}</p>
    </div>

</body>
</html>